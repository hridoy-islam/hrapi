<!DOCTYPE html
	PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">

<head>
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="x-apple-disable-message-reformatting" />
	<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
	<meta name="color-scheme" content="light dark" />
	<meta name="supported-color-schemes" content="light dark" />
	<title></title>
	<style type="text/css" rel="stylesheet" media="all">
		@import url("https://fonts.googleapis.com/css?family=Nunito+Sans:400,700&display=swap");

		body {
			width: 100% !important;
			height: 100%;
			margin: 0;
			padding: 0;
			-webkit-text-size-adjust: none;

		}

		body,
		td,
		th {
			font-family: "Nunito Sans", Helvetica, Arial, sans-serif;
			color: #51545e;
		}

		a img {
			border: none;
		}

		td {
			word-break: break-word;
		}

		p,
		ul,
		ol,
		blockquote {
			margin: 0.4em 0 1.1875em;
			font-size: 15px;
			line-height: 1.625;
			color: #000;
		}

		.email-wrapper {
			width: 100%;
			margin: 0;
			padding: 40px 0;
		}

		.email-content {
			width: 100%;
			margin: 0;
			padding: 0;
		}

		.email-card {
			width: 570px;
			margin: 0 auto;
			background: linear-gradient(135deg, #fafafa 0%, #f6f6f6 20%);
			border-radius: 16px;
			box-shadow: 0 8px 30px rgba(0, 0, 0, 0.58);
			overflow: hidden;
		}

		/* Every td inside the card must be transparent */
		.email-card td {
			background: transparent !important;
		}

		/* Logo area */
		.card-masthead {
			padding: 28px 45px 20px;
			text-align: center;
			background: transparent !important;
		}

		.card-masthead_logo {
			max-width: 90px;
			height: 90px;
			width: 90px;
			border-radius: 50%;
			display: block;
			margin: 0 auto;
			object-fit: cover;
			border: none;
			outline: none;
			background: transparent;
		}

		.card-masthead_name {
			display: inline-block;
			font-size: 20px;
			font-weight: bold;
			color: #000;
			text-decoration: none;
			letter-spacing: 1px;
			background-color: rgba(255, 255, 255, 0.15);
			padding: 10px 28px;
			border-radius: 8px;
			border: 2px solid rgba(255, 255, 255, 0.4);
		}

		/* White inner content box */
		.card-body {
			margin: 0 20px 0;
			background-color: #000 !important;
			border-radius: 10px;
			padding: 28px 32px;
		}

		.card-body p {
			margin: 0 0 10px;
			font-size: 15px;
			line-height: 1.6;
			color: #000 !important;
		}

		.card-body p strong {
			color: #000 !important;
		}

		/* Inline link */
		.shift-link {
			color: #38bdf8;
			font-weight: bold;
			text-decoration: none;}

		/* Divider */
		.divider {
			border: none;
			border-top: 1px solid rgba(255, 255, 255, 0.3);
			margin: 16px 0;
		}

		/* Notice bar — sits on gradient, white text */
		.notice-bar {
			padding: 16px 20px 20px;
			text-align: center;
			background: transparent !important;
		}

		.notice-bar p {
			margin: 0;
			font-size: 13px;
			color: #000 !important;
			font-weight: 600;
		}

		/* Responsive */
		@media only screen and (max-width: 600px) {
			.email-card {
				width: 100% !important;
				border-radius: 0 !important;
			}

			.card-body {
				margin: 0 10px 0 !important;
				padding: 20px !important;
			}
		}

		/* Dark mode */
		@media (prefers-color-scheme: dark) {

			body,
			.email-wrapper {
				background-color: #1a1a2e !important;
			}

			.card-body {
				background-color: #1e1e2e !important;
			}

			.card-body p {
				color: #000 !important;
			}

			.card-body p strong {
				color: #000 !important;
			}

			.divider {
				border-top-color: rgba(255, 255, 255, 0.2) !important;
			}
		}
	</style>
</head>

<body>
	<table class="email-wrapper" width="100%" cellpadding="0" cellspacing="0" role="presentation">
		<tr>
			<td align="center">
				<table class="email-content" width="100%" cellpadding="0" cellspacing="0" role="presentation">

					<tr>
						<td align="center" style="padding: 0 20px;">

							<!-- Gradient Card -->
							<table class="email-card" align="center" width="570" cellpadding="0" cellspacing="0"
								role="presentation"
								style="background: linear-gradient(135deg,  #fafafa 0%, #f6f6f6 20%);">

								<!-- Logo — on gradient, no white bg -->
								<tr>
									<td class="card-masthead" align="center"
										style="padding: 28px 45px 20px; background: transparent !important;">
										<% if (companyImage) { %>
											<img src="<%= companyImage %>" alt="<%= companyName %>" width="90"
												height="90"
												style="max-width:90px; width:90px; height:90px; border-radius:50%; display:block; margin:0 auto; object-fit:cover; border:none; background:transparent;" />
											<% } else { %>
												<a href="https://hr.cyberpeers.co.uk"
													style="display:inline-block; font-size:20px; font-weight:bold; color:#000; text-decoration:none; letter-spacing:1px; background-color:rgba(255,255,255,0.15); padding:10px 28px; border-radius:8px; border:2px solid rgba(255,255,255,0.4);">
													<%= companyName %>
												</a>
												<% } %>
									</td>
								</tr>

								<!-- White content box -->
								<tr>
									<td style="padding: 0 20px 0; background: transparent !important;">
										<table width="100%" cellpadding="0" cellspacing="0" role="presentation">
											<tr>
												<td class="card-body" style="border-radius:10px; padding:28px 32px;">

													<p style="color:#000 !important;"><strong
															style="color:#000 !important;">Dear <%= username %>
																,</strong></p>

													<p style="color:#000 !important;">
														<%- description %>
													</p>


													<p style="color:#000 !important;">
														Please <a href="https://hr.cyberpeers.co.uk" class="shift-link"
															target="_blank">log in</a> to check your updated rota. If
														you need any assistance, feel free to contact the admin team.
													</p>

													<p style="color:#000 !important; margin-bottom: 4px;">
                                                        Kind regards,<br />
                                                        <strong><%= companyName %></strong>
                                                    </p>

                                                    <p style="font-size:13px; color:#000 !important; margin: 0 0 10px;">
                                                        <% 
                                                            const line1 = [address, cityOrTown].filter(v => v && v.trim()).join(', ');
                                                            const line2 = [stateOrProvince, country, postCode].filter(v => v && v.trim()).join(', ');
                                                        %>
                                                        <% if (line1) { %>
                                                            <%= line1 %><br />
                                                        <% } %>
                                                        <% if (line2) { %>
                                                            <%= line2 %>
                                                        <% } %>
                                                    </p>



												</td>
											</tr>
										</table>
									</td>
								</tr>

								<tr>
									<td align="center"
										style="padding: 16px 20px 22px; background: transparent !important;">
										<p style="margin:0; font-size:13px; color:#000;">
											Please don't reply to this email.
										</p>
									</td>
								</tr>

							</table>
						</td>
					</tr>

				</table>
			</td>
		</tr>
	</table>
</body>

</html>